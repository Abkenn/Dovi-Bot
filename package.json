{
  "name": "dovi-bot",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Dovi Bot",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "prisma generate && tsc --noEmit -p tsconfig.json",
    "check": "biome check .",
    "prepare": "husky",
    "test": "vitest --watch",
    "test:full": "vitest run",
    "test:typecheck": "tsc --noEmit -p tsconfig.test.json",
    "test:coverage": "vitest run --coverage",
    "test:dal": "playwright test -c playwright.dal.config.ts",
    "toolchain:check": "node scripts/verify-toolchain.mjs",
    "verify:push": "pnpm run toolchain:check && pnpm run check && pnpm run build && pnpm run test:typecheck && pnpm run test:coverage",
    "verify:push:full": "pnpm run verify:push && pnpm run test:dal",
    "boss-discussion:backfill": "tsx scripts/boss-discussion-backfill.ts",
    "boss-discussion:backfill:dry-run": "tsx scripts/boss-discussion-backfill.ts --dry-run",
    "community-topics:seed": "tsx scripts/community-topic-seed.ts",
    "format": "biome format --write .",
    "hook:pre-commit": "node scripts/hooks/pre-commit.mjs",
    "hook:pre-push": "node scripts/hooks/pre-push.mjs"
  },
  "keywords": [],
  "author": "Abken",
  "license": "ISC",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": "24.x",
    "pnpm": "10.33.2"
  },
  "volta": {
    "node": "24.16.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@playwright/test": "^1.60.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.8",
    "husky": "^9.1.7",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "type-fest": "^5.7.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sapphire/framework": "^5.5.0",
    "discord.js": "^14.26.4",
    "dotenv": "^17.3.1",
    "hono": "^4.12.25",
    "luxon": "^3.7.2",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "overrides": {
      "@hono/node-server": "1.19.14",
      "fast-uri": "3.1.2",
      "lodash": "4.18.1",
      "ws": "8.21.0"
    }
  }
}
