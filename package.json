{
  "name": "dovi-bot",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Dovi Bot",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:embedded-app": "rsbuild dev --root embedded-app",
    "start": "node --max-old-space-size=192 --max-semi-space-size=4 --import tsx src/index.ts",
    "build": "prisma generate && pnpm run build:embedded-app && tsc --noEmit -p tsconfig.json",
    "build:embedded-app": "rsbuild build --root embedded-app && tsc --noEmit -p embedded-app/tsconfig.json",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:status": "prisma migrate status",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:schema:diff": "prisma migrate diff --from-config-datasource --to-schema prisma/schema.prisma --exit-code",
    "check": "biome check .",
    "prepare": "husky",
    "test": "vitest --watch",
    "test:full": "vitest run",
    "test:embedded-app": "vitest run --config embedded-app/vitest.config.ts",
    "test:embedded-app:coverage": "vitest run --coverage --config embedded-app/vitest.config.ts",
    "test:typecheck": "tsc --noEmit -p tsconfig.test.json",
    "test:coverage": "vitest run --coverage",
    "test:dal": "playwright test -c playwright.dal.config.ts",
    "toolchain:check": "node scripts/verify-toolchain.mjs",
    "verify:push": "pnpm run toolchain:check && pnpm run check && pnpm run build && pnpm run test:typecheck && pnpm run test:coverage && pnpm run test:embedded-app:coverage",
    "verify:push:full": "pnpm run verify:push && pnpm run test:dal",
    "boss-discussion:backfill": "tsx scripts/boss-discussion-backfill.ts",
    "boss-discussion:backfill:dry-run": "tsx scripts/boss-discussion-backfill.ts --dry-run",
    "community-topics:seed": "tsx scripts/community-topic-seed.ts",
    "format": "biome check --write .",
    "hook:pre-commit": "node scripts/hooks/pre-commit.mjs",
    "hook:pre-push": "node scripts/hooks/pre-push.mjs"
  },
  "keywords": [],
  "author": "Abken",
  "license": "ISC",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": "24.x",
    "pnpm": "10.33.2"
  },
  "volta": {
    "node": "24.16.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@playwright/test": "^1.60.0",
    "@rsbuild/core": "^2.1.5",
    "@rsbuild/plugin-react": "^2.1.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.8",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.16",
    "prisma": "^7.8.0",
    "shadcn": "^4.13.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "type-fest": "^5.7.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@discord/embedded-app-sdk": "^2.5.0",
    "@hono/node-server": "^1.19.14",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-separator": "^1.1.11",
    "@sapphire/framework": "^5.5.0",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-start": "^1.168.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "discord.js": "^14.26.4",
    "dotenv": "^17.3.1",
    "hono": "^4.12.25",
    "lucide-react": "^1.24.0",
    "luxon": "^3.7.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "overrides": {
      "@hono/node-server": "1.19.14",
      "fast-uri": "3.1.2",
      "lodash": "4.18.1",
      "ws": "8.21.0"
    }
  }
}
