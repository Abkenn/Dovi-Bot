generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum StreamKind {
  MUSIC
  GAME
  OTHER
}

enum MusicMode {
  DEMOCRACY
  DICTATORSHIP
  CAPITALISM
  UNKNOWN
}

enum ScheduleStatus {
  SCHEDULED
  CANCELLED
}

model GuildConfig {
  guildId               String   @id
  canonicalTimezone     String   @default("America/Sao_Paulo")
  currentWindowMinutes  Int      @default(240)
  lookaheadDays         Int      @default(21)

  defaultStreamKind     StreamKind @default(GAME)
  defaultGameName       String?
  defaultMusicMode      MusicMode?
  defaultTitleOverride  String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  defaults  StreamScheduleDefault[]
  overrides StreamScheduleOverride[]
}

model StreamScheduleDefault {
  id              String   @id @default(cuid())
  guildId         String
  weekday         Weekday
  startMinutes    Int
  isEnabled       Boolean  @default(true)
  durationMinutes Int      @default(240)

  streamKind      StreamKind?
  musicMode       MusicMode?
  titleOverride   String?
  gameName        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guild GuildConfig @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

  @@unique([guildId, weekday])
  @@index([guildId, weekday])
}

model StreamScheduleOverride {
  id                  String         @id @default(cuid())
  guildId             String
  streamDateKey       String
  resolvedFromWeekday Weekday?
  status              ScheduleStatus @default(SCHEDULED)
  startAtUtc          DateTime?
  durationMinutes     Int?

  streamKind          StreamKind?
  musicMode           MusicMode?
  titleOverride       String?
  gameName            String?

  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  guild GuildConfig @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

  @@unique([guildId, streamDateKey])
  @@index([guildId, streamDateKey])
}

model StreamInfoMessage {
  id        String   @id @default(cuid())
  guildId   String
  channelId String
  messageId String   @unique
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([guildId, channelId])
  @@index([guildId])
  @@index([channelId])
  @@index([updatedAt])
}

model PingMeSubscription {
  id            String   @id @default(cuid())
  userId        String
  sourceGuildId String
  keywords      String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, sourceGuildId])
  @@index([sourceGuildId])
}

enum CommandExecutionStatus {
  SUCCESS
  ERROR
  TIMEOUT
  DENIED
}

enum BossEncounterSource {
  DAVI_SPREADSHEET
  USER_SUBMITTED
}

enum BossTrialStatus {
  ACTIVE
  RESULTS_PUBLISHED
}

enum BossTrialVoteVerdict {
  PEAK
  FAIR
  MID
  BULLSHIT
}

enum BossTrialBumpMode {
  DEFAULT
  MID_POLL_ONLY
  NONE
}

enum BossTrackingSessionStatus {
  ACTIVE
  PAUSED
  ENDED
  CANCELLED
}

enum BossTrackingEndResult {
  KILLED
  ABANDONED
}

enum BossTrackingAttemptResult {
  IN_PROGRESS
  DEATH
  KILLED
  ABANDONED
  CANCELLED
}

enum BossTrackingAttemptTimingStatus {
  TRUSTED
  RECONCILED
}

enum BossTopicTermKind {
  ALIAS
  WEAK_ALIAS
  CONTEXT
}

model CommandExecutionLog {
  id              String                 @id @default(cuid())
  guildId         String?
  channelId       String?
  userId          String
  username        String?
  commandName     String
  optionsJson     Json?
  status          CommandExecutionStatus
  note            String?
  durationMs      Int?
  createdAt       DateTime               @default(now())

  errorLog        CommandErrorLog?

  @@index([createdAt])
  @@index([commandName, createdAt])
  @@index([status, createdAt])
  @@index([guildId, createdAt])
}

model CommandErrorLog {
  id                 String              @id @default(cuid())
  commandExecutionId String              @unique
  errorName          String?
  errorMessage       String?
  stack              String?
  discordCode        Int?
  httpStatus         Int?
  rawJson            Json?
  createdAt          DateTime            @default(now())

  commandExecution   CommandExecutionLog @relation(fields: [commandExecutionId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

model BossGame {
  id             String   @id @default(cuid())
  name           String
  normalizedName String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  bosses           Boss[]
  trials           BossTrial[]
  trackingSessions BossTrackingSession[]
  topicTerms       BossGameTopicTerm[]
}

model Boss {
  id             String   @id @default(cuid())
  gameId         String
  name           String
  normalizedName String
  runbackSeconds Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  game             BossGame               @relation(fields: [gameId], references: [id], onDelete: Cascade)
  stats            BossEncounterStat[]
  trials           BossTrial[]
  trackingSessions BossTrackingSession[]
  topicTerms       BossTopicTerm[]

  @@unique([gameId, normalizedName])
  @@index([gameId])
}

model BossEncounterStat {
  id                       String              @id @default(cuid())
  bossId                   String
  playerDiscordUserId      String
  source                   BossEncounterSource
  deaths                   Int?
  totalAttemptTimeSeconds  Int?
  winningAttemptTimeSeconds Int?
  difficultyCoefficient    Decimal?            @db.Decimal(10, 3)
  rawTotalAttemptTime      String?
  rawWinningAttemptTime    String?
  rawDifficultyCoefficient String?
  sourceRowNumber          Int?
  syncedAt                 DateTime            @default(now())
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt

  boss Boss @relation(fields: [bossId], references: [id], onDelete: Cascade)

  @@unique([bossId, playerDiscordUserId, source])
  @@index([playerDiscordUserId, source])
}

model BossTrial {
  id                       String          @id @default(cuid())
  guildId                  String
  channelId                String
  messageId                String?         @unique
  requesterUserId          String
  gameId                   String
  bossId                   String
  durationMinutes          Int
  voteVisibilityHiddenUntil DateTime
  endsAt                   DateTime
  bumpMode                 BossTrialBumpMode @default(DEFAULT)
  liveResultsPublishedAt   DateTime?
  automaticBumpPostedAt    DateTime?
  finalResultsPostedAt     DateTime?
  status                   BossTrialStatus @default(ACTIVE)
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  game  BossGame        @relation(fields: [gameId], references: [id], onDelete: Cascade)
  boss  Boss            @relation(fields: [bossId], references: [id], onDelete: Cascade)
  votes BossTrialVote[]
  bumpMessages BossTrialBumpMessage[]

  @@index([guildId, channelId])
  @@index([guildId, createdAt])
  @@index([guildId, requesterUserId, createdAt])
  @@index([status, endsAt])
  @@index([voteVisibilityHiddenUntil])
  @@index([automaticBumpPostedAt])
}

model BossTrialBumpMessage {
  id        String   @id @default(cuid())
  trialId   String
  messageId String   @unique
  createdAt DateTime @default(now())

  trial BossTrial @relation(fields: [trialId], references: [id], onDelete: Cascade)

  @@index([trialId, createdAt])
}

model BossTrialVote {
  id        String                @id @default(cuid())
  trialId   String
  userId    String
  verdict   BossTrialVoteVerdict
  votedAt   DateTime              @default(now())
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  trial BossTrial @relation(fields: [trialId], references: [id], onDelete: Cascade)

  @@unique([trialId, userId])
  @@index([trialId, votedAt])
  @@index([userId, votedAt])
}

model BossTrackingSession {
  id                 String                    @id @default(cuid())
  guildId            String
  channelId          String
  trackerUserId      String
  gameId             String
  bossId             String
  status             BossTrackingSessionStatus @default(ACTIVE)
  startDeaths        Int                       @default(0)
  deathCount         Int                       @default(0)
  recordedDeathCount Int                       @default(0)
  finalDeaths        Int?
  manualTrackedSeconds Int?
  vodLabel           String?
  vodStartSeconds    Int?
  vodEndSeconds      Int?
  attemptTimingStatus BossTrackingAttemptTimingStatus @default(TRUSTED)
  reconciliationNote String?
  totalPausedSeconds Int                       @default(0)
  pausedAt           DateTime?
  startedAt          DateTime                  @default(now())
  focusedAt          DateTime                  @default(now())
  endedAt            DateTime?
  endResult          BossTrackingEndResult?
  notes              String?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  game     BossGame              @relation(fields: [gameId], references: [id], onDelete: Cascade)
  boss     Boss                  @relation(fields: [bossId], references: [id], onDelete: Cascade)
  attempts BossTrackingAttempt[]
  pauses   BossTrackingPause[]

  @@index([guildId, status, startedAt])
  @@index([guildId, status, focusedAt])
  @@index([guildId, trackerUserId, startedAt])
  @@index([bossId, startedAt])
}

model BossTrackingAttempt {
  id            String                    @id @default(cuid())
  sessionId     String
  attemptNumber Int
  startedAt     DateTime                  @default(now())
  endedAt       DateTime?
  vodStartSeconds Int?
  vodEndSeconds Int?
  runbackSeconds Int?
  result        BossTrackingAttemptResult @default(IN_PROGRESS)
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  session BossTrackingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, attemptNumber])
  @@index([sessionId, result])
}

model BossTrackingPause {
  id        String   @id @default(cuid())
  sessionId String
  startedAt DateTime @default(now())
  endedAt   DateTime?
  reason    String?
  vodLabel  String?
  vodResumeSeconds Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session BossTrackingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, startedAt])
}

model BossTopicTerm {
  id             String            @id @default(cuid())
  bossId         String
  kind           BossTopicTermKind
  value          String
  normalizedValue String
  createdByUserId String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  boss Boss @relation(fields: [bossId], references: [id], onDelete: Cascade)

  @@unique([bossId, kind, normalizedValue])
  @@index([kind, normalizedValue])
}

model BossGameTopicTerm {
  id             String            @id @default(cuid())
  gameId         String
  kind           BossTopicTermKind
  value          String
  normalizedValue String
  createdByUserId String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  game BossGame @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([gameId, kind, normalizedValue])
  @@index([kind, normalizedValue])
}

model CommunityTopicMessageScan {
  id               String   @id @default(cuid())
  guildId          String
  channelId        String
  messageId        String   @unique
  authorUserId     String
  messageCreatedAt DateTime
  contentHash      String
  source           String
  signalCount      Int      @default(0)
  analyzedAt       DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  signals CommunityTopicSignal[]

  @@index([guildId, messageCreatedAt])
  @@index([guildId, channelId, messageCreatedAt])
  @@index([guildId, authorUserId, messageCreatedAt])
  @@index([source, analyzedAt])
}

model CommunityTopicSignal {
  id                 String   @id @default(cuid())
  scanId             String
  guildId            String
  channelId          String
  messageId          String
  authorUserId       String
  messageCreatedAt   DateTime
  topicKind          String
  entityKey          String
  entityName         String
  gameName           String?
  matchedAliases     Json
  matchedWeakAliases Json
  contextWords       Json
  confidence         Float
  intensity          Float
  createdAt          DateTime @default(now())

  scan CommunityTopicMessageScan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@unique([scanId, topicKind, entityKey])
  @@index([guildId, topicKind, messageCreatedAt])
  @@index([guildId, entityKey, messageCreatedAt])
  @@index([guildId, authorUserId, messageCreatedAt])
  @@index([guildId, topicKind, entityKey, messageCreatedAt])
}
