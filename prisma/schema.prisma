generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum StreamKind {
  MUSIC
  GAME
  OTHER
}

enum MusicMode {
  DEMOCRACY
  DICTATORSHIP
  CAPITALISM
  UNKNOWN
}

enum ScheduleStatus {
  SCHEDULED
  CANCELLED
}

model GuildConfig {
  guildId               String   @id
  canonicalTimezone     String   @default("Europe/Bucharest")
  currentWindowMinutes  Int      @default(300)
  lookaheadDays         Int      @default(21)

  currentStreamGame     String?
  nextStreamGame        String?
  nextStreamGamePoll    String?
  streamTitleOverride   String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  defaults  StreamScheduleDefault[]
  overrides StreamScheduleOverride[]
}

model StreamScheduleDefault {
  id              String   @id @default(cuid())
  guildId         String
  weekday         Weekday
  startMinutes    Int
  isEnabled       Boolean  @default(true)
  streamKind      StreamKind
  musicMode       MusicMode?
  titleOverride   String?
  gameName        String?
  durationMinutes Int      @default(300)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guild GuildConfig @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

  @@unique([guildId, weekday])
  @@index([guildId, weekday])
}

model StreamScheduleOverride {
  id              String         @id @default(cuid())
  guildId         String
  streamDateKey   String
  status          ScheduleStatus @default(SCHEDULED)
  startAtUtc      DateTime?
  streamKind      StreamKind?
  musicMode       MusicMode?
  titleOverride   String?
  gameName        String?
  durationMinutes Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guild GuildConfig @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

  @@unique([guildId, streamDateKey])
  @@index([guildId, streamDateKey])
}
