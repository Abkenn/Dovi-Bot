{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "rootDir": "src",
    "outDir": "dist",
    "paths": {
      "@zod-schemas/*": ["./src/types/zod-schemas/*"],
      "@data/*": ["./src/data/*"]
    }
  },
  "include": ["src"]
}
